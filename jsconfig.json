{
  "compilerOptions": {
    "checkJs": true,
    "strict": false,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ES6",
    "target": "ES6",
    "moduleResolution": "node"
  },
  "include": [
    "src/**/*",
    "*.js"
  ],
  "exclude": [
    "node_modules"
  ]
}
